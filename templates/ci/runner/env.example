# Gitea Actions Runner Configuration
# Copy this file to .env and fill in values for your server.
# Tested with Gitea Actions runner
#
# IMPORTANT: Labels here are only read during FIRST registration.
# After that, labels come from config.yaml runner.labels section.
# To change labels: edit config.yaml, delete /data/.runner, restart runner.

# Gitea instance URL (uses DNS/failover name)
GITEA_INSTANCE_URL=https://gitea.example.com

# Runner registration token (get from Gitea admin or run register.sh)
RUNNER_TOKEN=

# Server-specific labels
# Format: label:execution-mode
#   docker://<image>  -> job runs in a Docker container using that image
#   host              -> job runs directly in the runner container
#
# primary-server (active):
# RUNNER_LABELS=self-hosted:docker://node:20-bookworm,primary-server:docker://node:20-bookworm,active-capable:docker://node:20-bookworm,linux_amd64:host
#
# secondary-server (standby/passive):
# RUNNER_LABELS=self-hosted:docker://node:20-bookworm,secondary-server:docker://node:20-bookworm,passive-capable:docker://node:20-bookworm,linux_amd64:host

RUNNER_LABELS=self-hosted:docker://node:20-bookworm,primary-server:docker://node:20-bookworm,active-capable:docker://node:20-bookworm,linux_amd64:host
